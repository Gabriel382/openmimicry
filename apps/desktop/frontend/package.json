{
  "name": "@openmimicry/desktop-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "OpenMimicry desktop frontend (M7): overlay + panel routes, WS client, runtime registry.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
