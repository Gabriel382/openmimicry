# pnpm security-hardening (pnpm 11.x).
# Documented in SECURITY.md.
package-manager-strict=true
engine-strict=true

# Refuse any package version published within the last N days.
# Defends against newly-compromised package versions before they're detected.
# Tune up for production releases; tune down only for one-off experiments.
minimum-release-age=14
minimum-release-age-exclude=

# Block transitive dependencies whose source is not the npm registry
# (git+ssh, git+https, http(s) tarball URLs, file:, link:). A registry
# package cannot smuggle in a non-registry dependency.
block-exotic-subdeps=true

# Refuse to run install lifecycle scripts unless the package is on the
# `onlyBuiltDependencies` allowlist in pnpm-workspace.yaml. Equivalent
# to `pnpm install --ignore-scripts` by default, opt-in per package.
ignore-scripts=true

# Lockfile discipline
prefer-frozen-lockfile=true
frozen-lockfile=true
strict-peer-dependencies=true
auto-install-peers=false
resolution-mode=highest

# Disable telemetry
update-notifier=false
