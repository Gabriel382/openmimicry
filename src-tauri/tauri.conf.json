{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMimicry",
  "version": "0.1.0",
  "identifier": "com.openmimicry.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "OpenMimicry Overlay",
        "url": "/overlay",
        "width": 500,
        "height": 700,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "panel",
        "title": "OpenMimicry Panel",
        "url": "/panel",
        "width": 420,
        "height": 720,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": false
      }
    ]
  }
}