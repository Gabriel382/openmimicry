{
  "name": "openmimicry-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "OpenMimicry JavaScript workspace root. Use pnpm 11.x (see SECURITY.md).",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "install:safe": "pnpm install --frozen-lockfile",
    "audit": "pnpm audit --prod --audit-level=moderate",
    "approve-builds": "pnpm approve-builds",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build"
  },
  "pnpm": {
    "overrides": {
      "vite": "5.4.21"
    }
  }
}