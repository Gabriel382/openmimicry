# OpenMimicry frontend (development image).
#
# This image runs Vite's dev server and is meant for browser-based
# testing of the panel + overlay. Production deployments serve the
# built `dist/` from any static host or behind the Tauri shell.
#
# Build:   docker build -f docker/Dockerfile.frontend-dev -t openmimicry-frontend-dev:1.0.0 .
# Compose: docker compose up frontend-dev

FROM node:20-bookworm-slim AS dev

ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH

# pnpm 11 via corepack so the workspace's `packageManager` field is
# honoured exactly.
RUN corepack enable && corepack prepare pnpm@11.0.0 --activate

WORKDIR /workspace

# Copy the workspace manifest + lockfile first to keep the install
# layer cache-warm across source-only edits.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc /workspace/
COPY apps/desktop/frontend/package.json /workspace/apps/desktop/frontend/

RUN pnpm install --frozen-lockfile --filter @openmimicry/desktop-frontend...

COPY apps/desktop/frontend /workspace/apps/desktop/frontend

EXPOSE 5173

# Vite needs `--host 0.0.0.0` to be reachable from outside the
# container. `OPENMIMICRY_BACKEND_HOST` lets compose point the WS
# proxy at the backend service by name.
ENV OPENMIMICRY_BACKEND_HOST=http://backend:8000

CMD ["pnpm", "--filter", "@openmimicry/desktop-frontend", "exec", "vite", "--host", "0.0.0.0", "--port", "5173"]
